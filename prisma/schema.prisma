generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["uni-hungry"]
}

model User {
  id        String   @id @default(uuid()) // Mesmo ID do auth.users do Supabase
  email     String   @unique
  name      String?
  phone     String?
  role      UserRole @default(USER) // Role customizada!
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users") // Mapeia para a tabela auth.users do Supabase
  @@schema("uni-hungry")
}

// Enum para roles customizadas
enum UserRole {
  ADMIN // Administrador total
  MANAGER // Gerente de restaurante
  USER // Usuário comum
  WAITER // Garçom

  @@schema("uni-hungry")
}
