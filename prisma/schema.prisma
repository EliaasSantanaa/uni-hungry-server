generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["uni-hungry"]
}

model User {
  id           String   @id @default(uuid()) // Mesmo ID do auth.users do Supabase
  email        String   @unique
  name         String?
  phone        String?
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  restaurantId String? // FK para Restaurant (apenas MANAGER e WAITER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("users")
  @@schema("uni-hungry")
}

model Restaurant {
  id        String   @id @default(uuid())
  name      String
  cnpj      String?  @unique
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  isActive  Boolean  @default(true)
  ownerId   String // ID do MANAGER (dono)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  employees User[] // Todos os usuários vinculados (MANAGER, WAITER)
  menuItems MenuItem[]
  tables    Table[]

  @@map("restaurants")
  @@schema("uni-hungry")
}

model MenuItem {
  id           String       @id @default(uuid())
  name         String
  description  String?
  price        Decimal      @db.Decimal(10, 2)
  category     MenuCategory
  isAvailable  Boolean      @default(true)
  imageUrl     String?
  restaurantId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tabItems   TabItem[]

  @@index([restaurantId, category])
  @@index([restaurantId, isAvailable])
  @@map("menu_items")
  @@schema("uni-hungry")
}

model Table {
  id           String      @id @default(uuid())
  number       Int?
  name         String?
  capacity     Int?
  status       TableStatus @default(AVAILABLE)
  restaurantId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tabs       Tab[]

  @@index([restaurantId])
  @@map("tables")
  @@schema("uni-hungry")
}

model Tab {
  id            String         @id @default(uuid())
  tableId       String
  status        TabStatus      @default(OPEN)
  subtotal      Decimal        @default(0) @db.Decimal(10, 2)
  serviceCharge Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal        @default(0) @db.Decimal(10, 2)
  paymentMethod PaymentMethod?
  note          String?
  openedAt      DateTime       @default(now())
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  table Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  items TabItem[]

  @@index([tableId, status])
  @@map("tabs")
  @@schema("uni-hungry")
}

model TabItem {
  id         String   @id @default(uuid())
  tabId      String
  menuItemId String
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tab      Tab      @relation(fields: [tabId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([tabId])
  @@map("tab_items")
  @@schema("uni-hungry")
}

// Enum para roles customizadas
enum UserRole {
  ADMIN // Administrador do sistema (acesso total)
  MANAGER // Dono de restaurante (acesso apenas ao seu restaurante)
  WAITER // Garçom (acesso apenas ao seu restaurante)
  USER // Usuário comum (não usado no admin)

  @@schema("uni-hungry")
}

enum MenuCategory {
  BEBIDAS
  SOBREMESAS
  PRATO_PRINCIPAL
  ENTRADAS
  ACOMPANHAMENTOS

  @@schema("uni-hungry")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  INACTIVE

  @@schema("uni-hungry")
}

enum TabStatus {
  OPEN
  CLOSED
  CANCELLED

  @@schema("uni-hungry")
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD

  @@schema("uni-hungry")
}
